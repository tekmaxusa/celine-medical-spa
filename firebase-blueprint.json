{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "merchant"] },
        "photoURL": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "email", "role"]
    },
    "services": {
      "title": "Service",
      "description": "Available spa treatments.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "duration", "price"]
    },
    "specialists": {
      "title": "Specialist",
      "description": "Staff members performing treatments.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "bio": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "bookings": {
      "title": "Booking",
      "description": "Appointment records.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "UID of the client" },
        "specialistId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "specialistId", "serviceId", "date", "time", "status", "createdAt"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global application settings and booking rules.",
      "type": "object",
      "properties": {
        "businessHours": { "type": "object" },
        "leadTimeHours": { "type": "integer" },
        "cancellationWindowHours": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles indexed by UID."
    },
    "/services/{serviceId}": {
      "schema": "services",
      "description": "Collection of available services."
    },
    "/specialists/{specialistId}": {
      "schema": "specialists",
      "description": "Collection of spa specialists."
    },
    "/bookings/{bookingId}": {
      "schema": "bookings",
      "description": "All appointment bookings."
    },
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global settings."
    }
  }
}
